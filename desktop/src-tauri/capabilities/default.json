{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window. Reads and writes ~/.claudeversations/ — the persistent store for Claude state, reflections, conversations, and identity.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-home-read-recursive",
    "fs:allow-home-write-recursive",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/.claudeversations" },
        { "path": "$HOME/.claudeversations/**" }
      ]
    }
  ]
}
